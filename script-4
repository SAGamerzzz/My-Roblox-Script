local function StartFly()
    local rp=GetRootPart(); local hum=GetHumanoid()
    if not rp or not hum then return end
    flyEnabled=true
    if flyBody then flyBody:Destroy() end
    if flyGyro then flyGyro:Destroy() end
    flyBody=Instance.new("BodyVelocity",rp)
    flyBody.Velocity=Vector3.zero
    flyBody.MaxForce=Vector3.new(1e5,1e5,1e5)
    flyGyro=Instance.new("BodyGyro",rp)
    flyGyro.MaxTorque=Vector3.new(1e5,1e5,1e5); flyGyro.P=1e4
    hum.PlatformStand=true
    -- Mobile jump button → lift
    flyJumpConn=UIS.JumpRequest:Connect(function()
        flyJumpHeld=true
        task.delay(0.18,function() flyJumpHeld=false end)
    end)
    FlyBtn.Text="✈  Fly: ON"; SetOn(FlyBtn,FlyBtnS,C.green)
end

