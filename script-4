-- =================================================================
local function OptimizeObj(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter") or obj:IsA("Smoke")
        or obj:IsA("Fire") or obj:IsA("Sparkles") then obj.Enabled=false
        elseif obj:IsA("Explosion") then obj.Visible=false
        elseif obj:IsA("MeshPart") or obj:IsA("Part")
        or obj:IsA("CornerWedgePart") or obj:IsA("WedgePart") or obj:IsA("TrussPart") then
            if not ESP_IGNORE[obj.Name] and obj.Name~="AutoFarmMarker" then
                obj.Material=Enum.Material.SmoothPlastic
                obj.Reflectance=0; obj.CastShadow=false
            end
        elseif obj:IsA("Decal") or obj:IsA("Texture") then obj.Transparency=1
        elseif obj:IsA("Sky")        then obj.Parent=nil
        elseif obj:IsA("Atmosphere") then obj.Density=0;obj.Glare=0;obj.Haze=0
        end
    end)
end

local function DoFPSBoost()
    if fpsBoosted then return end; fpsBoosted=true
    pcall(function()
        UserSettings():GetService("UserGameSettings").SavedQualityLevel=
            Enum.SavedQualitySetting.QualityLevel1
    end)
    Lighting.GlobalShadows=false; Lighting.FogEnd=9e9
    task.spawn(function()
        local desc=game:GetDescendants()
        for i,o in ipairs(desc) do OptimizeObj(o); if i%400==0 then task.wait() end end
    end)
    game.DescendantAdded:Connect(OptimizeObj)
    FPSBtn.Text="🚀  FPS Boost: ON";   SetOn(FPSBtn,FPSBtnS,C.green)
    FPSBtn2.Text="🚀  FPS Boost: ON";  SetOn(FPSBtn2,FPSBtn2S,C.green)
end

