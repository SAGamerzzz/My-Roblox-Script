-- DRAGGABLE
-- =================================================================
local function MakeDraggable(gui)
    local startPos, startGuiPos, dragging = nil, nil, false
    gui.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        dragging = true; startPos = inp.Position; startGuiPos = gui.Position
    end)
    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = inp.Position - startPos
        if d.Magnitude > 6 then
            gui.Position = UDim2.new(
                startGuiPos.X.Scale, startGuiPos.X.Offset + d.X,
                startGuiPos.Y.Scale, startGuiPos.Y.Offset + d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
end

