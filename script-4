-- =================================================================
-- PLAYER ESP
-- =================================================================
local espEnabled    = false
local espHighlights = {}

local function RemoveESP()
    for _, h in pairs(espHighlights) do pcall(function() h:Destroy() end) end
    espHighlights = {}
end

local function AddESP(plr)
    if plr == LocalPlayer then return end
    local ch = plr.Character; if not ch then return end
    if espHighlights[plr] and espHighlights[plr].Parent then return end
    local h = Instance.new("SelectionBox")
    h.Name = "ESP_"..plr.Name; h.Color3 = C.red; h.LineThickness = 0.04
    h.SurfaceTransparency = 1; h.Adornee = ch; h.Parent = CoreGui
    espHighlights[plr] = h
end

RunService.Heartbeat:Connect(function()
    if not espEnabled then return end
    for plr, h in pairs(espHighlights) do
        if not plr or not plr.Character then
            pcall(function() h:Destroy() end); espHighlights[plr] = nil
        elseif h.Adornee ~= plr.Character then h.Adornee = plr.Character end
    end
    for _, plr in ipairs(Players:GetPlayers()) do AddESP(plr) end
end)

ESPBtn.MouseButton1Click:Connect(function()
    espEnabled = not espEnabled
    ESPBtn.Text = espEnabled and "Player ESP: ON" or "Player ESP: OFF"
    if espEnabled then
        SetOn(ESPBtn, ESPBtnS, C.green)
        for _, p in ipairs(Players:GetPlayers()) do AddESP(p) end
    else SetOff(ESPBtn, ESPBtnS); RemoveESP() end
end)

