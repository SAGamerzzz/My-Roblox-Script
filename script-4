local function MakeButton(name, text, accentCol, order)
    local btn    = Instance.new("TextButton", ScrollFrame)
    local stroke = Instance.new("UIStroke", btn)
    btn.Name = name; btn.Size = UDim2.new(0,232,0,40)
    btn.BackgroundColor3 = C.bg2; btn.Font = Enum.Font.GothamBold
    btn.Text = text; btn.TextColor3 = C.textMid; btn.TextSize = 12
    btn.LayoutOrder = order; btn.ZIndex = 5
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,11)
    stroke.Color = accentCol or C.accent; stroke.Thickness = 1.2; stroke.Transparency = 0.5
    btn.MouseEnter:Connect(function()
        Tween(stroke,{Transparency=0.1}); Tween(btn,{BackgroundColor3=C.bg2h})
    end)
    btn.MouseLeave:Connect(function()
        Tween(stroke,{Transparency=0.5}); Tween(btn,{BackgroundColor3=C.bg2})
    end)
    return btn, stroke
end

