local function SwitchTab(name)
    for n, page in pairs(tabPages) do
        if n == name then
            page.Visible=true
            Tween(page,{GroupTransparency=0})
        else
            page.Visible=false
        end
    end
    for n, data in pairs(tabBtns) do
        if n == name then
            Tween(data.btn,{BackgroundColor3=C.bg2h, TextColor3=C.textHi})
            Tween(data.stroke,{Color=C.accent, Transparency=0.1})
            -- Slide-in indicator
            if data.indicator then
                Tween(data.indicator,{BackgroundTransparency=0}, tweenMed)
            end
        else
            Tween(data.btn,{BackgroundColor3=C.bg2, TextColor3=C.textDim})
            Tween(data.stroke,{Color=C.accentDim, Transparency=0.8})
            if data.indicator then
                Tween(data.indicator,{BackgroundTransparency=1})
            end
        end
    end
    activeTab=name
end

local function RegisterTab(name, icon, label, order)
    local page = MakeTabPage()
    local btn, stroke = MakeTabBtn(icon, label, order)
    -- Active indicator bar (left edge)
    local indicator=Instance.new("Frame",btn)
    indicator.Size=UDim2.new(0,3,0.6,0); indicator.Position=UDim2.new(0,0,0.2,0)
    indicator.BackgroundColor3=C.accent; indicator.BackgroundTransparency=1
    indicator.BorderSizePixel=0; indicator.ZIndex=8
    Instance.new("UICorner",indicator).CornerRadius=UDim.new(0,4)
    RegisterThemed(indicator,{BackgroundColor3="accent"})
    tabPages[name]=page
    tabBtns[name]={btn=btn, stroke=stroke, indicator=indicator}
    btn.MouseButton1Click:Connect(function() SwitchTab(name) end)
    return page
end

