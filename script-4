-- =================================================================
local FAKE_ESP_COLOR=Color3.fromRGB(180,80,255)
local FAKE_ESP_FILL=Color3.fromRGB(160,60,255)
local ESP_IGNORE={DeltaStatic_InvisibleFloor=true,NavMarker=true,AutoFarmMarker=true,HumanoidRootPart=true}

local function IsFakeBlock(part)
    if not part:IsA("BasePart") then return false end
    if part.CanCollide          then return false end
    if ESP_IGNORE[part.Name]    then return false end
    for _,plr in ipairs(Players:GetPlayers()) do
        local ch=plr.Character
        if ch and part:IsDescendantOf(ch) then return false end
    end
    if platformPart and part==platformPart then return false end
    return true
end

local function ClearFakeESP()
    for _,box in pairs(fakeESPHighlights) do pcall(function() box:Destroy() end) end
    fakeESPHighlights={}; espCountLbl.Text="Blocks found: —"; espCountLbl.TextColor3=C.textDim
end

local function BuildFakeESP()
    for part,box in pairs(fakeESPHighlights) do
        if not part or not part.Parent or part.CanCollide then
            pcall(function() box:Destroy() end); fakeESPHighlights[part]=nil
        end
    end
    local count=0
    for _,obj in ipairs(workspace:GetDescendants()) do
        if IsFakeBlock(obj) then
            count=count+1
            if not fakeESPHighlights[obj] or not fakeESPHighlights[obj].Parent then
                local box=Instance.new("SelectionBox")
                box.Name="FakeESP_Box"; box.Adornee=obj
                box.Color3=FAKE_ESP_COLOR; box.LineThickness=0.06
                box.SurfaceColor3=FAKE_ESP_FILL; box.SurfaceTransparency=0.78
                box.Parent=CoreGui; fakeESPHighlights[obj]=box
            end
        end
    end
    espCountLbl.Text="👻  "..count.." fake block"..(count==1 and "" or "s").." found"
    espCountLbl.TextColor3=count>0 and C.textPurple or C.textDim
end

local function StartFakeESP()
    fakeESPEnabled=true; FakeESPBtn.Text="👻  Fake Block ESP: ON"
    SetOn(FakeESPBtn,FakeESPBtnS,C.green); BuildFakeESP()
    fakeESPConnection=task.spawn(function()
        while fakeESPEnabled do task.wait(2); if fakeESPEnabled then BuildFakeESP() end end
    end)
    workspace.DescendantAdded:Connect(function(obj)
        if not fakeESPEnabled then return end; task.wait()
        if IsFakeBlock(obj) and not fakeESPHighlights[obj] then
            local box=Instance.new("SelectionBox")
            box.Name="FakeESP_Box"; box.Adornee=obj
            box.Color3=FAKE_ESP_COLOR; box.LineThickness=0.06
            box.SurfaceColor3=FAKE_ESP_FILL; box.SurfaceTransparency=0.78
            box.Parent=CoreGui; fakeESPHighlights[obj]=box
        end
    end)
end

local function StopFakeESP()
    fakeESPEnabled=false; ClearFakeESP()
    FakeESPBtn.Text="👻  Fake Block ESP: OFF"
    SetOff(FakeESPBtn,FakeESPBtnS,C.purple)
end

