-- TROLL — THROW INTO VOID
-- =================================================================
ThrowBtn.MouseButton1Click:Connect(function()
    if not selectedTrollPlayer then
        trollStatusLbl.Text="⚠  No player selected!"
        trollStatusLbl.TextColor3=C.red
        task.delay(1.5,function()
            trollStatusLbl.Text="Select a player first"
            trollStatusLbl.TextColor3=C.textDim
        end)
        return
    end
    local targetCh=selectedTrollPlayer.Character
    if not targetCh then
        trollStatusLbl.Text="⚠  Player has no character"; trollStatusLbl.TextColor3=C.red
        return
    end
    -- Save our own position first
    local ourRp=GetRootPart()
    local savedPos=ourRp and ourRp.CFrame

    local targetRp=targetCh:FindFirstChild("HumanoidRootPart")
    if targetRp then
        -- Move them far below the map
        targetRp.CFrame=CFrame.new(0,-5000,0)
        trollStatusLbl.Text="✅  "..selectedTrollPlayer.Name.." thrown!"
        trollStatusLbl.TextColor3=C.green
    end

    -- Safely return our player if we moved
    if ourRp and savedPos then
        task.delay(0.1,function()
            ourRp.CFrame=savedPos
        end)
    end
    task.delay(2,function()
        trollStatusLbl.Text="Select a player first"
        trollStatusLbl.TextColor3=C.textDim
    end)
end)

-- =================================================================
-- PRESET SAVE / LOAD
-- =================================================================
local function GetCurrentPreset()
    return {
        airJump=airJumpEnabled, noclip=noclipEnabled, fly=flyEnabled,
        extreme=extremeSpeedEnabled, speedLock=speedLockEnabled,
        platform=platformEnabled, platformCollide=platformCollide,
        bright=brightEnabled, esp=espEnabled, fakeESP=fakeESPEnabled,
        seeThru=seeThruEnabled, fov=fovEnabled,
        currentSpeed=currentSpeed, currentJump=currentJump, fastWalkSpeed=fastWalkSpeed,
    }
end

SavePresetBtn.MouseButton1Click:Connect(function()
    savedPreset=GetCurrentPreset()
    presetStatusLbl.Text="✅  Preset saved!"
    presetStatusLbl.TextColor3=C.green
    Tween(SavePresetBtn,{TextColor3=C.textOn})
    task.delay(1.5,function()
        presetStatusLbl.Text="Saves current toggle states (client only)"
        presetStatusLbl.TextColor3=C.textDim
        Tween(SavePresetBtn,{TextColor3=C.textMid})
    end)
end)

LoadPresetBtn.MouseButton1Click:Connect(function()
    if not next(savedPreset) then
        presetStatusLbl.Text="⚠  No preset saved yet!"; presetStatusLbl.TextColor3=C.red
        task.delay(1.5,function()
            presetStatusLbl.Text="Saves current toggle states (client only)"
            presetStatusLbl.TextColor3=C.textDim
        end)
        return
    end
    -- Apply preset
    if savedPreset.airJump~=airJumpEnabled then AirJumpBtn:TriggerMouseButton1Click() end
    if savedPreset.noclip~=noclipEnabled    then NoclipBtn:TriggerMouseButton1Click()  end
    if savedPreset.bright~=brightEnabled    then BrightBtn:TriggerMouseButton1Click()  end
    if savedPreset.esp~=espEnabled          then ESPBtn:TriggerMouseButton1Click()     end
    if savedPreset.platform~=platformEnabled then ApplyPlatform(savedPreset.platform)  end
    presetStatusLbl.Text="✅  Preset loaded!"; presetStatusLbl.TextColor3=C.green
    task.delay(1.5,function()
        presetStatusLbl.Text="Saves current toggle states (client only)"
        presetStatusLbl.TextColor3=C.textDim
    end)
end)

