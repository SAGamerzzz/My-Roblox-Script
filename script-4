RunService.RenderStepped:Connect(function()
    if not flyEnabled or not flyBody or not flyGyro then return end
    local cam=workspace.CurrentCamera
    local hum=GetHumanoid()
    local dir=Vector3.zero

    -- PC keyboard
    if UIS:IsKeyDown(Enum.KeyCode.W)         then dir=dir+cam.CFrame.LookVector  end
    if UIS:IsKeyDown(Enum.KeyCode.S)         then dir=dir-cam.CFrame.LookVector  end
    if UIS:IsKeyDown(Enum.KeyCode.A)         then dir=dir-cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.D)         then dir=dir+cam.CFrame.RightVector end
    if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.yAxis           end
    if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.yAxis           end

    -- Mobile joystick: use humanoid MoveDirection projected flat
    if hum and hum.MoveDirection.Magnitude>0.1 then
        local md=hum.MoveDirection
        local flat=Vector3.new(md.X,0,md.Z)
        if flat.Magnitude>0.01 then
            -- Project joystick onto camera-relative axes
            local fwd=Vector3.new(cam.CFrame.LookVector.X,0,cam.CFrame.LookVector.Z).Unit
            local rgt=Vector3.new(cam.CFrame.RightVector.X,0,cam.CFrame.RightVector.Z).Unit
            dir=dir+(fwd*md.Z+rgt*md.X)
        end
    end

    -- Mobile jump button lift
    if flyJumpHeld then dir=dir+Vector3.yAxis end

    flyBody.Velocity=dir.Magnitude>0 and dir.Unit*60 or Vector3.zero
    flyGyro.CFrame=cam.CFrame
end)

