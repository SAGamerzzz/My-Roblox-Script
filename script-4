local speedSliderUpdate = nil
local function MakeSlider(name, text, minV, maxV, default, order, callback)
    local frame = Instance.new("Frame", ScrollFrame)
    frame.Name = name; frame.Size = UDim2.new(0,232,0,54)
    frame.BackgroundColor3 = C.bg2; frame.LayoutOrder = order; frame.ZIndex = 5
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0,11)
    local fStroke = Instance.new("UIStroke", frame)
    fStroke.Color = C.accentDim; fStroke.Thickness = 1.1; fStroke.Transparency = 0.6
    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1,-10,0,22); title.Position = UDim2.new(0,10,0,4)
    title.BackgroundTransparency = 1; title.Font = Enum.Font.GothamBold
    title.Text = text..":  "..default; title.TextColor3 = C.textMid
    title.TextSize = 11; title.TextXAlignment = Enum.TextXAlignment.Left; title.ZIndex = 6
    local track = Instance.new("Frame", frame)
    track.Size = UDim2.new(0,208,0,6); track.Position = UDim2.new(0.5,-104,0,37)
    track.BackgroundColor3 = Color3.fromRGB(28,30,50); track.ZIndex = 6
    Instance.new("UICorner", track).CornerRadius = UDim.new(0,3)
    local sliderMax = maxV
    local unit0 = math.clamp((default-minV)/(sliderMax-minV),0,1)
    local curVal = default
    local bar = Instance.new("Frame", track)
    bar.Size = UDim2.new(unit0,0,1,0); bar.BackgroundColor3 = C.accent; bar.ZIndex = 7
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0,3)
    local dot = Instance.new("Frame", track)
    dot.Size = UDim2.new(0,14,0,14); dot.Position = UDim2.new(unit0,-7,0.5,-7)
    dot.BackgroundColor3 = C.textHi; dot.ZIndex = 8
    Instance.new("UICorner", dot).CornerRadius = UDim.new(0,7)
    local snap = false
    local function updateSlider(input)
        local u = math.clamp(
            (input.Position.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        curVal = math.floor(minV+(sliderMax-minV)*u)
        title.Text = text..":  "..curVal
        bar.Size = UDim2.new(u,0,1,0); dot.Position = UDim2.new(u,-7,0.5,-7)
        callback(curVal)
    end
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            snap = true; updateSlider(inp) end
    end)
    UIS.InputChanged:Connect(function(inp)
        if not snap then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then updateSlider(inp) end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then snap = false end
    end)
    if name == "SpeedSlider" then
        speedSliderUpdate = function(newMax)
            sliderMax = newMax
            if curVal > sliderMax then curVal = sliderMax end
            local u = math.clamp((curVal-minV)/(sliderMax-minV),0,1)
            title.Text = text..":  "..curVal
            bar.Size = UDim2.new(u,0,1,0); dot.Position = UDim2.new(u,-7,0.5,-7)
            callback(curVal)
        end
    end
end

