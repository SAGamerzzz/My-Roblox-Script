local function ActivateUltraFPS()
    ultraFPSActive=true; WarnPopup.Visible=false
    local function applyTo(btn,btnS,wl,wl2)
        if not btn then return end
        btn.Text="⚡  Ultra FPS Boost: ON"
        Tween(btnS,{Color=C.green,Transparency=0})
        Tween(btn, {TextColor3=C.textOn})
        if wl  then wl.Text="✅  Ultra mode active";           wl.TextColor3=C.green end
        if wl2 then wl2.Text="Rejoin to restore game visuals"; wl2.TextColor3=Color3.fromRGB(80,160,80) end
    end
    applyTo(UltraFPSBtn,UltraFPSBtnS,ultraWarnLbl,ultraWarnLbl2)
    applyTo(UltraBtn2,UltraBtn2S,nil,nil)
    pcall(function()
        UserSettings():GetService("UserGameSettings").SavedQualityLevel=
            Enum.SavedQualitySetting.QualityLevel1
    end)
    Lighting.GlobalShadows=false; Lighting.FogEnd=9e9; Lighting.Brightness=0
    Lighting.Ambient=Color3.fromRGB(128,128,128)
    Lighting.OutdoorAmbient=Color3.fromRGB(128,128,128)
    Lighting.ShadowSoftness=0
    for _,ch in ipairs(Lighting:GetChildren()) do pcall(function()
        if ch:IsA("Sky") then ch:Destroy()
        elseif ch:IsA("Atmosphere") then ch.Density=0;ch.Glare=0;ch.Haze=0
        elseif ch:IsA("BloomEffect") or ch:IsA("SunRaysEffect")
        or ch:IsA("ColorCorrectionEffect") or ch:IsA("DepthOfFieldEffect")
        or ch:IsA("BlurEffect") then ch.Enabled=false end
    end) end
    local SAFE={DeltaStatic_InvisibleFloor=true,NavMarker=true,AutoFarmMarker=true}
    task.spawn(function()
        local all=workspace:GetDescendants()
        for i,obj in ipairs(all) do pcall(function()
            if obj:IsA("BasePart") then
                local isChar=false
                for _,plr in ipairs(Players:GetPlayers()) do
                    if plr.Character and obj:IsDescendantOf(plr.Character) then isChar=true;break end
                end
                if not isChar and not SAFE[obj.Name] then
                    obj.Material=Enum.Material.SmoothPlastic
                    obj.Reflectance=0; obj.CastShadow=false
                end
            elseif obj:IsA("Decal") or obj:IsA("Texture")         then obj.Transparency=1
            elseif obj:IsA("ParticleEmitter") or obj:IsA("Smoke")
            or obj:IsA("Fire") or obj:IsA("Sparkles")             then obj.Enabled=false
            elseif obj:IsA("Explosion")                            then obj.Visible=false
            elseif obj:IsA("Sound")                                then obj.Volume=0
            elseif obj:IsA("Trail") or obj:IsA("Beam")            then obj.Enabled=false
            elseif obj:IsA("SpecialMesh")                          then obj.TextureId=""
            elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then obj.Enabled=false
            end
        end)
        if i%250==0 then task.wait() end end
        workspace.DescendantAdded:Connect(function(obj)
            if not ultraFPSActive then return end
            pcall(function()
                if obj:IsA("ParticleEmitter") or obj:IsA("Smoke")
                or obj:IsA("Fire") or obj:IsA("Sparkles") then obj.Enabled=false
                elseif obj:IsA("Decal") or obj:IsA("Texture") then obj.Transparency=1
                elseif obj:IsA("Sound")                       then obj.Volume=0
                elseif obj:IsA("Trail") or obj:IsA("Beam")    then obj.Enabled=false
                elseif obj:IsA("BillboardGui") or obj:IsA("SurfaceGui") then obj.Enabled=false
                end
            end)
        end)
    end)
end

