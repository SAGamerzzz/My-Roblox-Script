local tweenFast = TweenInfo.new(0.15, Enum.EasingStyle.Quad)
local tweenMed  = TweenInfo.new(0.28, Enum.EasingStyle.Quad)
local tweenBounce = TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

local function Tween(obj, props, info)
    TweenService:Create(obj, info or tweenFast, props):Play()
end

-- Theme-aware object registry for live switching
local themedObjects = {}
local function RegisterThemed(obj, propMap)
    table.insert(themedObjects, {obj=obj, propMap=propMap})
end

local function ApplyTheme(theme)
    currentTheme = theme
    C = Themes[theme]
    for _, entry in ipairs(themedObjects) do
        local props = {}
        for prop, key in pairs(entry.propMap) do
            props[prop] = C[key]
        end
        Tween(entry.obj, props, tweenMed)
    end
end

local function SetOn(btn, stroke, col)
    col = col or C.green
    Tween(stroke, {Color=col, Transparency=0})
    Tween(btn,    {TextColor3=C.textOn})
end

local function SetOff(btn, stroke, col)
    col = col or C.accent
    Tween(stroke, {Color=col, Transparency=0.5})
    Tween(btn,    {TextColor3=C.textMid})
end

-- =================================================================
-- DRAGGABLE
-- =================================================================
local function MakeDraggable(gui)
    local startPos, startGuiPos, dragging = nil, nil, false
    gui.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        dragging=true; startPos=inp.Position; startGuiPos=gui.Position
    end)
    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d = inp.Position - startPos
        if d.Magnitude > 6 then
            gui.Position = UDim2.new(
                startGuiPos.X.Scale, startGuiPos.X.Offset+d.X,
                startGuiPos.Y.Scale, startGuiPos.Y.Offset+d.Y)
        end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.Touch
        or inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
end

