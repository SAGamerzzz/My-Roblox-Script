-- SEE THROUGH WALLS
-- =================================================================
local function ApplySeeThru(enable)
    for _,c in pairs(seeThruConnections) do pcall(function() c:Disconnect() end) end
    seeThruConnections={}
    if enable then
        local function makeThru(obj)
            if not obj:IsA("BasePart") and not obj:IsA("MeshPart") then return end
            for _,plr in ipairs(Players:GetPlayers()) do
                if plr.Character and obj:IsDescendantOf(plr.Character) then return end
            end
            if ESP_IGNORE[obj.Name] then return end
            pcall(function() obj.LocalTransparencyModifier=0.6 end)
        end
        for _,obj in ipairs(workspace:GetDescendants()) do makeThru(obj) end
        local conn=workspace.DescendantAdded:Connect(function(obj)
            task.wait(); if seeThruEnabled then makeThru(obj) end
        end)
        table.insert(seeThruConnections,conn)
    else
        for _,obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") or obj:IsA("MeshPart") then
                pcall(function() obj.LocalTransparencyModifier=0 end)
            end
        end
    end
end

SeeThruBtn.MouseButton1Click:Connect(function()
    seeThruEnabled=not seeThruEnabled
    SeeThruBtn.Text=seeThruEnabled and "🔍  See Through Walls: ON" or "🔍  See Through Walls: OFF"
    if seeThruEnabled then SetOn(SeeThruBtn,SeeThruBtnS,C.green)
    else SetOff(SeeThruBtn,SeeThruBtnS,C.purple) end
    ApplySeeThru(seeThruEnabled)
end)

