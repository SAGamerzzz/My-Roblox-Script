-- ৪. বাটন তৈরি করার ফাংশন (অপ্টিমাইজড সাইজ)
local menuTweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Quad)
local function CreateMenuButton(name, text, color, order)
    local Button = Instance.new("TextButton")
    local BCorn = Instance.new("UICorner")
    
    Button.Name = name
    Button.Size = UDim2.new(0, 200, 0, 32)            -- ল্যান্ডস্কেপ সাইজ ২০০x৩২
    Button.BackgroundColor3 = color
    Button.Font = Enum.Font.SourceSansBold
    Button.Text = text
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 13                               -- টেক্সট সাইজ ১৩
    Button.LayoutOrder = order
    Button.ClipsDescendants = true
    
    BCorn.CornerRadius = UDim.new(0, 6)
    BCorn.Parent = Button
    Button.Parent = ScrollFrame                        -- ScrollFrame-এ সেট করা হয়েছে
    
    Button.MouseEnter:Connect(function()
        if Button.BackgroundColor3 ~= Color3.fromRGB(38, 166, 91) then
            TweenService:Create(Button, menuTweenInfo, {BackgroundTransparency = 0.2}):Play()
        end
    end)
    Button.MouseLeave:Connect(function()
        TweenService:Create(Button, menuTweenInfo, {BackgroundTransparency = 0}):Play()
    end)
    
    return Button
end

-- ৫. স্লাইডার তৈরি করার অ্যাডভান্সড ফাংশন (অপ্টিমাইজড সাইজ)
local speedSliderUpdate = nil 

local function CreateSlider(name, text, min, max, default, order, callback)
    local SliderFrame = Instance.new("Frame")
    local SliderTitle = Instance.new("TextLabel")
    local SliderContainer = Instance.new("Frame")
    local SliderBar = Instance.new("Frame")
    local SliderDot = Instance.new("Frame")
    local DotCorner = Instance.new("UICorner")
    local FrameCorn = Instance.new("UICorner")
    local BarCorn = Instance.new("UICorner")

    SliderFrame.Name = name
    SliderFrame.Size = UDim2.new(0, 200, 0, 44)        -- ল্যান্ডস্কেপ সাইজ ২০০x৪৪
    SliderFrame.BackgroundColor3 = Color3.fromRGB(45, 52, 54)
    SliderFrame.LayoutOrder = order
    FrameCorn.CornerRadius = UDim.new(0, 6)
    FrameCorn.Parent = SliderFrame

    SliderTitle.Size = UDim2.new(1, 0, 0, 20)
    SliderTitle.BackgroundTransparency = 1
    SliderTitle.Font = Enum.Font.SourceSansBold
    SliderTitle.Text = text .. ": " .. default
    SliderTitle.TextColor3 = Color3.fromRGB(255, 255, 255)
    SliderTitle.TextSize = 12
    SliderTitle.Parent = SliderFrame

    SliderContainer.Size = UDim2.new(0, 180, 0, 4)
    SliderContainer.Position = UDim2.new(0.5, -90, 0.75, -2)
    SliderContainer.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    BarCorn.CornerRadius = UDim.new(0, 2)
    BarCorn.Parent = SliderContainer
    SliderContainer.Parent = SliderFrame

    local currentSliderMax = max
    SliderBar.Size = UDim2.new(math.clamp((default - min) / (currentSliderMax - min), 0, 1), 0, 1, 0)
    SliderBar.BackgroundColor3 = Color3.fromRGB(30, 144, 255)
    Instance.new("UICorner", SliderBar).CornerRadius = UDim.new(0, 2)
    SliderBar.Parent = SliderContainer

    SliderDot.Size = UDim2.new(0, 10, 0, 10)
    SliderDot.Position = UDim2.new(math.clamp((default - min) / (currentSliderMax - min), 0, 1), -5, 0.5, -5)
    SliderDot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    DotCorner.CornerRadius = UDim.new(0, 5)
    DotCorner.Parent = SliderDot
    SliderDot.Parent = SliderContainer

    SliderFrame.Parent = ScrollFrame                   -- ScrollFrame-এ সেট করা হয়েছে

    local snap = false
    local currentSliderValue = default

    local function update(input)
        local unit = math.clamp((input.Position.X - SliderContainer.AbsolutePosition.X) / SliderContainer.AbsoluteSize.X, 0, 1)
        currentSliderValue = math.floor(min + (currentSliderMax - min) * unit)
        SliderTitle.Text = text .. ": " .. currentSliderValue
        SliderBar.Size = UDim2.new(unit, 0, 1, 0)
        SliderDot.Position = UDim2.new(unit, -5, 0.5, -5)
        callback(currentSliderValue)
    end

    SliderContainer.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            snap = true
            update(input)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if snap and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            snap = false
        end
    end)

    if name == "SpeedSlider" then
        speedSliderUpdate = function(newMax)
            currentSliderMax = newMax
            if currentSliderValue > currentSliderMax then
                currentSliderValue = currentSliderMax
            end
            local unit = math.clamp((currentSliderValue - min) / (currentSliderMax - min), 0, 1)
            SliderTitle.Text = text .. ": " .. currentSliderValue
            SliderBar.Size = UDim2.new(unit, 0, 1, 0)
            SliderDot.Position = UDim2.new(unit, -5, 0.5, -5)
            callback(currentSliderValue)
        end
    end
end

