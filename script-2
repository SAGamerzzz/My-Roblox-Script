-- 📱 আলটিমেট মোবাইল অপ্টিমাইজড ড্র্যাগ ও ওপেন/ক্লোজ মেকানিজম (Fixed)
-- =================================================================
local function SafeMobileDragAndToggle(gui, isToggleButton)
    local dragStart, startPos
    local dragging = false
    local hasMovedSignificant = false
    local touchStartTime = 0

    -- টাচ স্ক্রিন বা মাউস ডাউন ইভেন্ট শুরু
    gui.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            hasMovedSignificant = false
            touchStartTime = os.clock()
            dragStart = input.Position
            startPos = gui.Position
        end
    end)

    -- আঙুল বা মাউস নড়াচড়া ট্র্যাক করা (Threshold সহ)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            
            -- ড্র্যাগ মুভমেন্ট তখনই সক্রিয় হবে যদি আঙুল অন্তত ৫ পিক্সেলের বেশি নড়ে
            if delta.Magnitude > 5 then
                hasMovedSignificant = true
                local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
                TweenService:Create(gui, TweenInfo.new(0.05, Enum.EasingStyle.OutQuad), {Position = targetPos}):Play()
            end
        end
    end)

    -- টাচ/ক্লিক শেষ হওয়া এবং অ্যাকশন নির্ধারণ
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if dragging then
                dragging = false
                
                -- যদি বাটনটি বেশি নড়াচড়া না করে এবং টাচ টাইম ০.২৫ সেকেন্ডের কম হয়, তবে এটি ১০০% নিখুঁত ট্যাপ!
                if isToggleButton and not hasMovedSignificant and (os.clock() - touchStartTime) < 0.25 then
                    MainFrame.Visible = not MainFrame.Visible
                    if MainFrame.Visible then
                        MenuToggleButton.Text = "X"
                        TweenService:Create(MenuToggleButton, menuTweenInfo, {BackgroundColor3 = Color3.fromRGB(231, 76, 60)}):Play()
                    else
                        MenuToggleButton.Text = "MENU"
                        TweenService:Create(MenuToggleButton, menuTweenInfo, {BackgroundColor3 = Color3.fromRGB(30, 144, 255)}):Play()
                    end
                end
            end
        end
    end)
end

