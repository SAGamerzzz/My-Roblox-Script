-- [ Fixed Reward-Safe Still Air-Lock Platform Logic ]
local function TogglePlatform(enable)
    if enable then
        if not platformPart or not platformPart.Parent then
            platformPart = Instance.new("Part")
            platformPart.Size = Vector3.new(6.5, 0.5, 6.5)
            platformPart.Anchored = true
            platformPart.Transparency = 1 
            platformPart.Name = "DeltaStatic_InvisibleFloor"
            platformPart.Parent = workspace
        end
        
        if not platformConnection then
            platformConnection = RunService.Heartbeat:Connect(function()
                local character = LocalPlayer.Character
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                if rootPart and platformPart then
                    local velocityY = rootPart.AssemblyLinearVelocity.Y
                    
                    if velocityY > 1 then
                        platformPart.CanCollide = false
                        platformPart.Position = rootPart.Position - Vector3.new(0, 3.6, 0)
                    else
                        platformPart.CanCollide = platformCollide
                        if platformCollide then
                            platformPart.Position = Vector3.new(rootPart.Position.X, platformPart.Position.Y, rootPart.Position.Z)
                        else
                            platformPart.Position = rootPart.Position - Vector3.new(0, 3.6, 0)
                        end
                    end
                end
            end)
        end
    else
        if platformConnection then platformConnection:Disconnect() platformConnection = nil end
        if platformPart then platformPart:Destroy() platformPart = nil end
    end
end

PlatformBtn.MouseButton1Click:Connect(function()
    platformEnabled = not platformEnabled
    if platformEnabled then
        TogglePlatform(true)
        PlatformBtn.Text = "Always Platform: ON"
        TweenService:Create(PlatformBtn, menuTweenInfo, {BackgroundColor3 = Color3.fromRGB(38, 166, 91)}):Play()
    else
