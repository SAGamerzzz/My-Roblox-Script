local function OptimizeObject(object)
    pcall(function()
        if object:IsA("ParticleEmitter") or object:IsA("Smoke") or object:IsA("Fire") or object:IsA("Sparkles") then
            object.Enabled = false
        elseif object:IsA("Explosion") then
            object.Visible = false
        elseif object:IsA("MeshPart") or object:IsA("Part") or object:IsA("CornerWedgePart") or object:IsA("WedgePart") or object:IsA("TrussPart") then
            if object.Name ~= "DeltaStatic_InvisibleFloor" then
                object.Material = Enum.Material.SmoothPlastic
                object.Reflectance = 0
            end
        elseif object:IsA("Decal") or object:IsA("Texture") then
            object:Destroy()
        end
    end)
end

local fpsBoosted = false
FPSBoostBtn.MouseButton1Click:Connect(function()
    if fpsBoosted then return end
    fpsBoosted = true
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd = 9e9
    task.spawn(function()
        local descendants = game:GetDescendants()
        for i, object in ipairs(descendants) do
            OptimizeObject(object)
            if i % 400 == 0 then task.wait() end
        end
    end)
    game.DescendantAdded:Connect(OptimizeObject)
    FPSBoostBtn.Text = "FPS Boosted"
    TweenService:Create(FPSBoostBtn, menuTweenInfo, {BackgroundColor3 = Color3.fromRGB(38, 166, 91)}):Play()
end)

