-- =================================================================
-- FPS BOOST
-- =================================================================
local function OptimizeObj(obj)
    pcall(function()
        if obj:IsA("ParticleEmitter") or obj:IsA("Smoke")
        or obj:IsA("Fire")           or obj:IsA("Sparkles") then
            obj.Enabled = false
        elseif obj:IsA("Explosion") then
            obj.Visible = false
        elseif obj:IsA("MeshPart") or obj:IsA("Part")
            or obj:IsA("CornerWedgePart") or obj:IsA("WedgePart")
            or obj:IsA("TrussPart") then
            if obj.Name ~= "DeltaStatic_InvisibleFloor" and obj.Name ~= "NavMarker" then
                obj.Material    = Enum.Material.SmoothPlastic
                obj.Reflectance = 0
            end
        elseif obj:IsA("Decal") or obj:IsA("Texture") then
            obj:Destroy()
        end
    end)
end

local fpsBoosted = false
FPSBtn.MouseButton1Click:Connect(function()
    if fpsBoosted then return end
    fpsBoosted = true
    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
    Lighting.GlobalShadows = false
    Lighting.FogEnd        = 9e9
    task.spawn(function()
        local desc = game:GetDescendants()
        for i, o in ipairs(desc) do
            OptimizeObj(o)
            if i % 400 == 0 then task.wait() end
        end
    end)
    game.DescendantAdded:Connect(OptimizeObj)
    FPSBtn.Text = "🚀  FPS Boosted ✓"; SetOn(FPSBtn, FPSBtnS)
end)

