local brightEnabled = false
BrightBtn.MouseButton1Click:Connect(function()
    brightEnabled = not brightEnabled
    local amb  = brightEnabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(128,128,128)
    local brit = brightEnabled and 2 or 1
    TweenService:Create(Lighting, TweenInfo.new(0.3),
        {Ambient = amb, OutdoorAmbient = amb, Brightness = brit}):Play()
    if brightEnabled then
        BrightBtn.Text = "☀  Full Bright: ON";  SetOn(BrightBtn, BrightBtnS)
    else
        BrightBtn.Text = "☀  Full Bright: OFF"; SetOff(BrightBtn, BrightBtnS, Color3.fromRGB(80,180,255))
    end
end)
