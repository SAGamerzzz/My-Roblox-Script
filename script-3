local menuTweenInfo = TweenInfo.new(0.18, Enum.EasingStyle.Quad)

local function Tween(obj, props)
    TweenService:Create(obj, menuTweenInfo, props):Play()
end

local function SetOn(btn, stroke)
    Tween(stroke, {Color = Color3.fromRGB(50,220,110), Transparency = 0})
    Tween(btn,    {TextColor3 = Color3.fromRGB(100,255,160)})
end

local function SetOff(btn, stroke, accent)
    accent = accent or Color3.fromRGB(80,180,255)
    Tween(stroke, {Color = accent, Transparency = 0.45})
    Tween(btn,    {TextColor3 = Color3.fromRGB(210,225,255)})
end

-- =================================================================
-- DRAG  (works on both PC and mobile; does NOT eat click events)
-- =================================================================
-- We track finger/mouse movement ourselves.  A "tap" is an InputBegan
-- followed by InputEnded with <10 px travel and <0.3 s — we do NOT
-- block that; we just move the GUI when travel > 10 px.
local function MakeDraggable(gui)
    local startPos, startGuiPos
    local dragging = false

    gui.InputBegan:Connect(function(inp)
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseButton1 then return end
        dragging    = true
        startPos    = inp.Position
        startGuiPos = gui.Position
    end)

    -- Use UIS.InputChanged so we don't lose tracking when the finger leaves the button
    UIS.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.Touch
        and inp.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local delta = inp.Position - startPos
        if delta.Magnitude > 10 then
            gui.Position = UDim2.new(
                startGuiPos.X.Scale, startGuiPos.X.Offset + delta.X,
                startGuiPos.Y.Scale, startGuiPos.Y.Offset + delta.Y)
        end
    end)

    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.Touch
        or inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

