local function StartGo()
    if not savedTargetPos then
        Tween(GoBtn, {TextColor3 = Color3.fromRGB(255,100,100)})
        task.delay(0.5, function() Tween(GoBtn, {TextColor3 = Color3.fromRGB(210,225,255)}) end)
        return
    end
    isGoingToTarget = true
    GoBtn.Text = "🚶  Going… (tap to stop)"; SetOn(GoBtn, GoBtnS)

    local function step()
        local ch  = LocalPlayer.Character
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        local rp  = ch and ch:FindFirstChild("HumanoidRootPart")
        if not hum or not rp then StopGo(); return end
        if (rp.Position - savedTargetPos).Magnitude < 3 then StopGo(); return end
        hum.WalkSpeed = fastWalkSpeed
        hum:MoveTo(savedTargetPos)
    end

    step()
    goToConnection = RunService.Heartbeat:Connect(function()
        if isGoingToTarget then step() end
    end)
end

GoBtn.MouseButton1Click:Connect(function()
    if isGoingToTarget then StopGo() else StartGo() end
end)

