local function MakeButton(name, text, accentColor, order)
    local btn    = Instance.new("TextButton")
    local corner = Instance.new("UICorner")
    local stroke = Instance.new("UIStroke")

    btn.Name            = name
    btn.Size            = UDim2.new(0,204,0,36)
    btn.BackgroundColor3= Color3.fromRGB(22,22,36)
    btn.Font            = Enum.Font.GothamBold
    btn.Text            = text
    btn.TextColor3      = Color3.fromRGB(210,225,255)
    btn.TextSize        = 12
    btn.LayoutOrder     = order
    btn.ZIndex          = 5

    corner.CornerRadius = UDim.new(0,10);   corner.Parent = btn
    stroke.Color        = accentColor
    stroke.Thickness    = 1.2
    stroke.Transparency = 0.45;             stroke.Parent = btn
    btn.Parent          = ScrollFrame

    btn.MouseEnter:Connect(function()
        Tween(stroke, {Transparency = 0.05})
        Tween(btn, {BackgroundColor3 = Color3.fromRGB(30,30,48)})
    end)
    btn.MouseLeave:Connect(function()
        Tween(stroke, {Transparency = 0.45})
        Tween(btn, {BackgroundColor3 = Color3.fromRGB(22,22,36)})
    end)

    return btn, stroke
end

local speedSliderUpdate = nil

local function MakeSlider(name, text, minV, maxV, default, order, callback)
    local frame  = Instance.new("Frame")
    local fCorner= Instance.new("UICorner")
    local fStroke= Instance.new("UIStroke")
    local title  = Instance.new("TextLabel")
    local track  = Instance.new("Frame")
    local tCorner= Instance.new("UICorner")
    local bar    = Instance.new("Frame")
    local bCorner= Instance.new("UICorner")
    local dot    = Instance.new("Frame")
    local dCorner= Instance.new("UICorner")

    frame.Name            = name
    frame.Size            = UDim2.new(0,204,0,50)
    frame.BackgroundColor3= Color3.fromRGB(20,20,32)
    frame.LayoutOrder     = order
    frame.ZIndex          = 5
    fCorner.CornerRadius  = UDim.new(0,10); fCorner.Parent = frame
    fStroke.Color         = Color3.fromRGB(80,180,255)
    fStroke.Thickness     = 1.2; fStroke.Transparency = 0.55
    fStroke.Parent        = frame

    title.Size            = UDim2.new(1,-10,0,22)
    title.Position        = UDim2.new(0,10,0,3)
    title.BackgroundTransparency = 1
    title.Font            = Enum.Font.GothamBold
    title.Text            = text..":  "..default
    title.TextColor3      = Color3.fromRGB(180,210,255)
    title.TextSize        = 11
    title.TextXAlignment  = Enum.TextXAlignment.Left
    title.ZIndex          = 6
    title.Parent          = frame

    track.Size            = UDim2.new(0,182,0,6)
    track.Position        = UDim2.new(0.5,-91,0,34)
    track.BackgroundColor3= Color3.fromRGB(35,35,55)
    track.ZIndex          = 6
    tCorner.CornerRadius  = UDim.new(0,3); tCorner.Parent = track
    track.Parent          = frame

    local sliderMax = maxV
    local unit0     = math.clamp((default-minV)/(sliderMax-minV),0,1)

    bar.Size            = UDim2.new(unit0,0,1,0)
    bar.BackgroundColor3= Color3.fromRGB(60,160,255)
    bar.ZIndex          = 7
    bCorner.CornerRadius= UDim.new(0,3); bCorner.Parent = bar
    bar.Parent          = track

    dot.Size            = UDim2.new(0,14,0,14)
    dot.Position        = UDim2.new(unit0,-7,0.5,-7)
    dot.BackgroundColor3= Color3.fromRGB(255,255,255)
    dot.ZIndex          = 8
    dCorner.CornerRadius= UDim.new(0,7); dCorner.Parent = dot
    dot.Parent          = track

    frame.Parent = ScrollFrame

    local snap  = false
    local curVal= default

    local function update(input)
        local u = math.clamp(
            (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        curVal = math.floor(minV + (sliderMax - minV) * u)
        title.Text = text..":  "..curVal
        bar.Size   = UDim2.new(u,0,1,0)
        dot.Position= UDim2.new(u,-7,0.5,-7)
        callback(curVal)
    end

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            snap = true; update(inp)
        end
    end)
    UIS.InputChanged:Connect(function(inp)
        if not snap then return end
        if inp.UserInputType == Enum.UserInputType.MouseMovement
        or inp.UserInputType == Enum.UserInputType.Touch then update(inp) end
    end)
    UIS.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then snap = false end
    end)

    if name == "SpeedSlider" then
        speedSliderUpdate = function(newMax)
            sliderMax = newMax
            if curVal > sliderMax then curVal = sliderMax end
            local u = math.clamp((curVal-minV)/(sliderMax-minV),0,1)
            title.Text   = text..":  "..curVal
            bar.Size     = UDim2.new(u,0,1,0)
            dot.Position = UDim2.new(u,-7,0.5,-7)
            callback(curVal)
        end
    end
end

