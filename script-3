-- =================================================================
-- PLATFORM LOGIC  (unchanged)
-- =================================================================
local function TogglePlatform(enable)
    if enable then
        if not platformPart or not platformPart.Parent then
            platformPart            = Instance.new("Part")
            platformPart.Size       = Vector3.new(6.5,0.5,6.5)
            platformPart.Anchored   = true
            platformPart.Transparency = 1
            platformPart.Name       = "DeltaStatic_InvisibleFloor"
            platformPart.Parent     = workspace
        end
        if not platformConnection then
            platformConnection = RunService.Heartbeat:Connect(function()
                local ch  = LocalPlayer.Character
                local rp  = ch and ch:FindFirstChild("HumanoidRootPart")
                if rp and platformPart then
                    local vy    = rp.AssemblyLinearVelocity.Y
                    local expP  = rp.Position - Vector3.new(0,3.6,0)
                    local dist  = (platformPart.Position - expP).Magnitude
                    if dist > 15 or vy > 1 then
                        platformPart.CanCollide = false
                        platformPart.Position   = expP
                    else
                        platformPart.CanCollide = platformCollide
                        if platformCollide then
                            platformPart.Position = Vector3.new(rp.Position.X, platformPart.Position.Y, rp.Position.Z)
                        else
                            platformPart.Position = expP
                        end
                    end
                end
            end)
        end
    else
        if platformConnection then platformConnection:Disconnect(); platformConnection = nil end
        if platformPart       then platformPart:Destroy();          platformPart       = nil end
    end
end

local function ApplyPlatform(enable)
    platformEnabled = enable
    TogglePlatform(enable)
    if enable then
        PlatformBtn.Text  = "⬛  Always Platform: ON"
        SetOn(PlatformBtn, PlatformBtnS)
        PlatActionBtn.Text = "⬛  Platform: ON"
        Tween(PlatActionBtn,  {TextColor3 = Color3.fromRGB(100,255,160)})
        Tween(PlatActionStroke,{Color = Color3.fromRGB(50,220,110), Transparency = 0.05})
    else
        PlatformBtn.Text  = "⬛  Always Platform: OFF"
        SetOff(PlatformBtn, PlatformBtnS, Color3.fromRGB(80,180,255))
        PlatActionBtn.Text = "⬛  Platform: OFF"
        Tween(PlatActionBtn,  {TextColor3 = Color3.fromRGB(200,200,220)})
        Tween(PlatActionStroke,{Color = Color3.fromRGB(80,180,255), Transparency = 0.5})
    end
end

