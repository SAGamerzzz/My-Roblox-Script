-- =================================================================
-- MARK LOCATION
-- Uses a dedicated connection that checks gameProcessed carefully
-- so it never intercepts normal button taps inside the GUI.
-- =================================================================
local markConnection = nil

local function ShowMarker(pos)
    if markerPart and markerPart.Parent then markerPart:Destroy() end
    markerPart                  = Instance.new("Part")
    markerPart.Name             = "NavMarker"
    markerPart.Size             = Vector3.new(1.2,0.3,1.2)
    markerPart.Anchored         = true
    markerPart.CanCollide       = false
    markerPart.Material         = Enum.Material.Neon
    markerPart.BrickColor       = BrickColor.new("Bright blue")
    markerPart.Transparency     = 0.3
    markerPart.Position         = pos
    markerPart.Parent           = workspace
end

local function StartMarking()
    markConnection = UIS.InputBegan:Connect(function(inp, gpe)
        -- gpe = true means the tap hit a GUI element → do NOT capture it
        if gpe then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseButton1
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end

        local cam = workspace.CurrentCamera
        local ray = cam:ScreenPointToRay(inp.Position.X, inp.Position.Y)
        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Exclude
        local excl = {}
        if LocalPlayer.Character then table.insert(excl, LocalPlayer.Character) end
        if markerPart            then table.insert(excl, markerPart)            end
        params.FilterDescendantsInstances = excl

        local result = workspace:Raycast(ray.Origin, ray.Direction * 1000, params)
        if result then
            savedTargetPos = result.Position
            ShowMarker(savedTargetPos)
            Tween(MarkBtn, {TextColor3 = Color3.fromRGB(80,255,160)})
            task.delay(0.4, function()
                Tween(MarkBtn, {TextColor3 = Color3.fromRGB(210,225,255)})
            end)
        end
    end)
end

local function StopMarking()
    if markConnection then markConnection:Disconnect(); markConnection = nil end
end

MarkBtn.MouseButton1Click:Connect(function()
    markingEnabled = not markingEnabled
    if markingEnabled then
        MarkBtn.Text = "📍  Mark Location: ON";  SetOn(MarkBtn, MarkBtnS)
        StartMarking()
    else
        MarkBtn.Text = "📍  Mark Location: OFF"; SetOff(MarkBtn, MarkBtnS, Color3.fromRGB(255,160,50))
        StopMarking()
    end
end)

